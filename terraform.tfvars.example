# ── Copy this to terraform.tfvars and fill in your values ──────────────────

aws_region           = "ap-south-1"       # Mumbai region
cluster_name         = "k8s-kubeadm"
master_instance_type = "t3.small"        # 2 vCPU, 4 GB RAM — minimum for kubeadm
worker_instance_type = "t3.small"
public_key_path      = "/home/cx/.ssh/terraform/id_rsa.pub"
allowed_ssh_cidr     = "157.50.194.114/32"       # e.g. "103.x.x.x/32"  ← replace this!
pod_network_cidr     = "10.244.0.0/16"    # Flannel default
k8s_version          = "1.29"
